# Zkopíruj tento soubor jako .env a doplň reálné hodnoty ze Supabase dashboardu.
# Supabase → Project Settings → API Keys

# Veřejné klíče (bezpečné v mobilní app díky RLS)
EXPO_PUBLIC_SUPABASE_URL=https://tvuj-projekt.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=ZDE_VLOZ_ANON_KEY

# POUZE pro seed skripty — NIKDY nepoužívat v app kódu!
# Po použití doporučujeme klíč rotovat (Supabase → API Keys → Regenerate)
SUPABASE_SERVICE_ROLE_KEY=ZDE_VLOZ_SERVICE_ROLE_KEY
